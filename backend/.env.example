# Required API keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Backend runtime
APP_NAME=UGP PLD Copilot API
APP_ENV=development
PORT=8000
API_RATE_LIMIT=20
FRONTEND_URL=https://frontend-aads19s-projects.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://frontend-aads19s-projects.vercel.app

# Persistence
DATABASE_PATH=./conversations.db

# Chroma
CHROMA_PATH=../chroma_store
CHROMA_COLLECTION_NAME=pvd_docs
CSV_PATH=../PLD CATEGORY FINAL DATASET.csv
RETRIEVAL_ENABLED=true
RETRIEVAL_TOP_K=3
RETRIEVAL_CANDIDATE_COUNT=9

# Models
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_ROUTER_MODEL=llama-3.1-8b-instant
LLM_REWRITE_MODEL=llama-3.1-8b-instant
LLM_GRADER_MODEL=llama-3.1-8b-instant
LLM_SYNTHESIS_MODEL=llama-3.1-8b-instant
LLM_CRITIC_MODEL=llama-3.1-8b-instant
LLM_FORMATTER_MODEL=llama-3.1-8b-instant
LLM_CHAT_MODEL=llama-3.1-8b-instant
LLM_HYDE_MODEL=llama-3.1-8b-instant
LLM_PARAPHRASE_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
